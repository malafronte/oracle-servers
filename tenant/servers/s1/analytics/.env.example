# =============================================================================
# Variabili d'ambiente — isola analytics (Waline + Umami + PostgreSQL)
# Server: malafronte-oci-s1 (ARM Ubuntu 24.04)
#
# Istruzioni:
#   1. Copia in .env:  cp .env.example .env
#   2. Compila con valori reali (le password generate dallo script sono già in .env)
#   3. .env è gitignorato, .env.example è versionato
# =============================================================================

# ─── Dominio del sito servito ───
SITE_DOMAIN=malafronte.dev

# ─── PostgreSQL ───
POSTGRES_USER=analytics
POSTGRES_PASSWORD=sostituisci-con-password-lunga-e-casuale
POSTGRES_DB=analytics
# I due database (waline, umami) vengono creati automaticamente da init-db.sql

# ─── Waline (sistema commenti + contatore visite) ───
WALINE_DOMAIN=comments.malafronte.dev
WALINE_DB_NAME=waline
SITE_NAME=malafronte.dev
SITE_URL=https://malafronte.dev
AUTHOR_EMAIL=admin@malafronte.eu
WALINE_LANG=it-IT
ALLOW_REGISTER=true
COMMENT_RATE_LIMIT=60

# ─── Umami (analytics) ───
UMAMI_DOMAIN=analytics.malafronte.dev
UMAMI_ADMIN_USER=admin
UMAMI_ADMIN_PASSWORD=sostituisci-con-password-sicura
# APP_SECRET generato automaticamente dallo script (openssl rand -hex 32)
APP_SECRET=sostituisci-con-hex-casuale

# ─── Timezone ───
TZ=Europe/Rome
