# CineBase — Configurazione produzione OCI (malafronte-oci-s1)
# Copiare questo file in .env e compilare con i valori reali.
#
# Variabili di servizio — da personalizzare prima del primo avvio:
#   MYSQL_ROOT_PASSWORD, JWT_SECRET, ADMIN_SEED_EMAIL, ADMIN_SEED_PASSWORD
#
# Variabili di integrazione esterna — compilare se disponibili:
#   SMTP_* (Aruba già configurato in .env.docker del repo CineBase)
#   STRIPE_*, GOOGLE_OAUTH_*, MICROSOFT_OAUTH_*, TMDB_BEARER_TOKEN

# ── MariaDB ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=film-api-db
DB_USER=cinebase
DB_PASSWORD=cinebase
DB_USE_AUTODETECT=false
DB_SERVER_VERSION=10.11.0-mariadb

# ── Backend / JWT ────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
JWT_SECRET=CineBaseDockerProductionJwtSecret_2026_Minimum32Bytes!
JWT_ISSUER=CineBaseAPI
JWT_AUDIENCE=CineBaseWeb
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7
ADMIN_SEED_EMAIL=admin@cinebase.it
ADMIN_SEED_PASSWORD=Admin123!

# ── URL pubbliche / CORS ─────────────────────────────────────────────────────
# In produzione dietro Traefik: frontend su www.cinebase.it, API su api.cinebase.it
FRONTEND_PUBLIC_BASE_URL=https://www.cinebase.it
CORS_ALLOWED_ORIGINS=https://www.cinebase.it
TICKET_VALIDATION_BASE_URL=/admin/biglietti/validazione
API_BASE_URL=https://api.cinebase.it/api
MEDIA_BASE_URL=https://api.cinebase.it/media
DEPLOYMENT_MODE=direct-backend
SHOW_DISCLAIMER=false

# ── Parametri applicativi ────────────────────────────────────────────────────
DEFAULT_COVER_IMAGE_PATH=/media/defaults/cover-default.jpg
DEFAULT_TICKET_PRICE=8.50
HOLD_TTL_MINUTES=10
DB_STARTUP_MAX_RETRIES=10
DB_STARTUP_RETRY_DELAY_SECONDS=3
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
SET_PASSWORD_TOKEN_TTL_MINUTES=60
ADMIN_INVITE_TOKEN_TTL_HOURS=24
AUTH_EXTERNAL_STATE_TTL_MINUTES=10
AUTH_EXTERNAL_EXCHANGE_TTL_MINUTES=2
ACCOUNT_DELETION_TOKEN_TTL_MINUTES=60
LOGIN_RATE_LIMIT_PERMITS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
FORGOT_PASSWORD_RATE_LIMIT_PERMITS=3
FORGOT_PASSWORD_RATE_LIMIT_WINDOW_SECONDS=300
REFRESH_TOKEN_CLEANUP_INTERVAL_MINUTES=30
HOLD_CLEANUP_INTERVAL_MINUTES=5
PENDING_ORDER_MAX_AGE_MINUTES=30

# ── Versioni legali ──────────────────────────────────────────────────────────
PRIVACY_POLICY_VERSION=2026-05-10-draft-01
TERMS_CONDITIONS_VERSION=2026-05-10-draft-01
COOKIE_POLICY_VERSION=2026-05-10-draft-01
LEGAL_DPO_ENABLED=false

# ── Seeder ───────────────────────────────────────────────────────────────────
SEED_SOURCE_MODE=snapshot
SEED_SNAPSHOT_FILE=/app/data/catalog-snapshot.json

# ── SMTP (Aruba, produzione) ──────────────────────────────────────────────────
SMTP_HOST=smtps.aruba.it
SMTP_PORT=465
SMTP_USER=noreply@cinebase.it
SMTP_PASSWORD=noreply@cinebase.it
SMTP_FROM_EMAIL=noreply@cinebase.it
SMTP_FROM_NAME=CineBase
SMTP_REQUIRE_AUTH=true
SMTP_SECURE_SOCKET_OPTIONS=SslOnConnect

# ── Stripe (opzionale: lascia vuoto per disabilitare) ─────────────────────────
STRIPE_SECRET_API_KEY=
STRIPE_PUBLISHABLE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Google OAuth (opzionale: lascia vuoto per disabilitare) ────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.cinebase.it/auth/external/google/callback
GOOGLE_REQUIRE_EMAIL_VERIFIED=true

# ── Microsoft OAuth (opzionale: lascia vuoto per disabilitare) ─────────────────
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=https://api.cinebase.it/auth/external/microsoft/callback
MICROSOFT_AUTHORITY=common
MICROSOFT_REQUIRE_EMAIL_CLAIM=true

# ── TMDB (opzionale: lascia vuoto per usare solo lo snapshot) ──────────────────
TMDB_BEARER_TOKEN=

# ── Logging ──────────────────────────────────────────────────────────────────
LOCAL_EMAIL_VERIFICATION_ENFORCED_SINCE_UTC=2026-05-19T00:00:00Z
SHOW_PRESHOW_MINUTES=15
SHOW_INTERVAL_MINUTES=15
SHOW_TURNAROUND_MINUTES=30
