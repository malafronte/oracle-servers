# =============================================================================
# Server s1 (malafronte-oci-s1) — Environment configuration
# =============================================================================
# Istruzioni:
#   1. Copia questo file in .env:  cp .env.example .env
#   2. Sostituisci i placeholder con i valori reali
#   3. .env è gitignorato (contiene segreti), .env.example è versionato
#   4. Sulla macchina Windows: gli script di rotazione chiavi e OCI lo caricano
#      con `Get-Content .env | ForEach-Object { if ($_ -match '^([^#].+?)=(.+)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process') } }`
#   5. Sul server Linux (dopo SCP): gli script bash lo caricano con `source .env`
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
S1_IP=<IP_ADDRESS>
S1_SSH_USER=ubuntu
# Percorso relativo alla ROOT del repository (oracle-servers/)
S1_SSH_KEY=./tenant/.secrets/s1/nome-chiave.key

# ─────────────────────────────────────────────────────────────────────────────
# DNS e dominio (per Traefik, registry, forgejo, netdata, portainer)
# ─────────────────────────────────────────────────────────────────────────────
# DOMAIN è il dominio base per i servizi INFRASTRUTTURALI:
#   traefik.${DOMAIN}  portainer.${DOMAIN}  registry.${DOMAIN}
#   git.${DOMAIN}      monitor.${DOMAIN}
#
# Per domini applicativi separati (es. cinebase.it), passa il dominio
# come secondo argomento a 09-progetto-template.sh:
#   bash 09-progetto-template.sh cinebase cinebase.it
DOMAIN=malafronte.eu
LETSENCRYPT_EMAIL=tua-email@esempio.com

# ─────────────────────────────────────────────────────────────────────────────
# Traefik (reverse proxy dashboard)
# ─────────────────────────────────────────────────────────────────────────────
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=TuaPasswordSicura123

# ─────────────────────────────────────────────────────────────────────────────
# Docker Registry privato
# ─────────────────────────────────────────────────────────────────────────────
REGISTRY_USER=tuo-utente
REGISTRY_PASSWORD=TuaPasswordSicura123

# ─────────────────────────────────────────────────────────────────────────────
# Forgejo (Git + CI/CD)
# ─────────────────────────────────────────────────────────────────────────────
FORGEJO_DB_PASSWORD=ForgejoDbP4ssw0rd!

# ─────────────────────────────────────────────────────────────────────────────
# Netdata (monitoring)
# ─────────────────────────────────────────────────────────────────────────────
NETDATA_DASHBOARD_USER=admin
NETDATA_DASHBOARD_PASSWORD=TuaPasswordSicura
# Opzionali: notifiche Telegram (lascia vuoto per disabilitare)
# Come configurarle:
#   1. Su Telegram cerca @BotFather, scrivi /newbot, segui istruzioni
#   2. Verifica token: https://api.telegram.org/bot<TOKEN>/getMe
#   3. Cerca il tuo bot, scrivigli /start
#   4. Ottieni chat_id: https://api.telegram.org/bot<TOKEN>/getUpdates
#      il valore è nel JSON: "chat" → "id"
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Backup su OCI Object Storage
# ─────────────────────────────────────────────────────────────────────────────
BACKUP_BUCKET_NAME=s1-backup

# ─────────────────────────────────────────────────────────────────────────────
# OCI — Tenant, compartimento, istanza, utente
# ─────────────────────────────────────────────────────────────────────────────
OCI_COMPARTMENT_ID=<OCID_TENANCY>
OCI_INSTANCE_ID=<OCID_INSTANCE>
OCI_USER_ID=<OCID_USER>
OCI_TENANCY_ID=<OCID_TENANCY>
OCI_REGION=<REGIONE_OCI>
OCI_KEY_FILE=<PERCORSO_LOCALE>\tenant\.secrets\oci-cli\oci_api_key.pem
OCI_FINGERPRINT=<FINGERPRINT_CHIAVE_API>
OCI_SESSION_PROFILE=<NOME_PROFILO_SESSIONE>

# ─────────────────────────────────────────────────────────────────────────────
# OCI — Networking (VCN, subnet, security list)
# Usati da: tenant/docs/sicurezza-oci-firewall.md, comandi CLI
# ─────────────────────────────────────────────────────────────────────────────
OCI_VCN_ID=<OCID_VCN>
OCI_SUBNET_ID=<OCID_SUBNET>
OCI_SECURITY_LIST_ID=<OCID_SECURITY_LIST>
OCI_VNIC_ID=<OCID_VNIC>

# ─────────────────────────────────────────────────────────────────────────────
# OCI CLI — autenticazione session (opzionale, in alternativa alla chiave API)
# Usato da: oci session authenticate --region eu-milan-1
# Dopo il login, i comandi vanno eseguiti con:
#   --profile $OCI_SESSION_PROFILE --auth security_token
# ─────────────────────────────────────────────────────────────────────────────
